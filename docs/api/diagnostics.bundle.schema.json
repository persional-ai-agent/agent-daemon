{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-daemon.local/schemas/diagnostics.bundle.v1.json",
  "title": "Diagnostics Bundle V1",
  "type": "object",
  "required": [
    "schema_version",
    "source",
    "exported_at",
    "session_id",
    "turn_id",
    "stream_mode",
    "configured_transport",
    "active_transport",
    "reconnect_status",
    "reconnect_count",
    "timeout_action",
    "read_timeout_sec",
    "turn_timeout_sec",
    "fallback_hint",
    "last_error_code",
    "error_text",
    "events"
  ],
  "properties": {
    "schema_version": { "const": "diag.v1" },
    "source": { "type": "string", "enum": ["web", "ui-tui"] },
    "exported_at": { "type": "string", "format": "date-time" },
    "session_id": { "type": "string", "minLength": 1 },
    "turn_id": { "type": "string" },
    "stream_mode": { "type": "boolean" },
    "configured_transport": { "type": "string", "enum": ["ws", "sse"] },
    "active_transport": { "type": "string", "enum": ["ws", "sse"] },
    "reconnect_status": { "type": "string", "enum": ["connecting", "resumed", "degraded", "failed"] },
    "reconnect_count": { "type": "integer", "minimum": 0 },
    "timeout_action": { "type": "string", "enum": ["wait", "reconnect", "cancel"] },
    "read_timeout_sec": { "type": "integer", "minimum": 1 },
    "turn_timeout_sec": { "type": "integer", "minimum": 1 },
    "fallback_hint": { "type": "string" },
    "last_error_code": { "type": "string" },
    "error_text": { "type": "string" },
    "events": {
      "type": "array",
      "items": { "type": "object" }
    }
  },
  "additionalProperties": true
}
