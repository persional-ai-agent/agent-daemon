[
  {
    "name": "chat_ws_success",
    "path": "/v1/chat/ws",
    "request": {
      "session_id": "s-ws",
      "message": "ping",
      "resume": true,
      "turn_id": "turn-ws-1"
    },
    "expect_events": [
      "session",
      "resumed",
      "user_message",
      "turn_started",
      "assistant_message",
      "completed",
      "result"
    ]
  },
  {
    "name": "chat_ws_invalid_json_error",
    "path": "/v1/chat/ws",
    "raw_request": "{broken-json",
    "expect_events": [
      "error"
    ]
  }
]
